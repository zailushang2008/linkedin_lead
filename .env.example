# App
APP_ENV=development
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=18000
SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=*

# Database
POSTGRES_USER=linkedin
POSTGRES_PASSWORD=linkedin
POSTGRES_DB=linkedin_lead
POSTGRES_HOST=postgres
POSTGRES_PORT=15432
DATABASE_URL=postgresql+psycopg2://linkedin:linkedin@postgres:5432/linkedin_lead

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=16379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:18000

# Scraper
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
SCRAPER_RATE_LIMIT_PER_MINUTE=30

# LinkedIn session (optional for worker scraper)
LINKEDIN_COOKIES_JSON=
LINKEDIN_STORAGE_STATE_PATH=
